# Shared tutorial configuration for chapters 01-04
# Copy this file to the repository root as .env.local once,
# then the runnable web chapters will reuse it automatically.

# Anthropic API Configuration
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Override the default model used by tutorial chapters that support it
ANTHROPIC_MODEL=minimax/minimax-m2.7

# Optional: Custom API endpoint，推荐使用 MiniMax API 作为代理
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
